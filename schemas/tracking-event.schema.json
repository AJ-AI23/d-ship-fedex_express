{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://api.qa.nshiftgo.com/schemas/tracking-event.json",
  "title": "Tracking Event",
  "description": "Single tracking event for register_event. Maps to nShift tracker status and event model.",
  "type": "object",
  "required": ["trackingNumber", "eventType", "timestamp"],
  "properties": {
    "trackingNumber": {
      "type": "string",
      "minLength": 1,
      "description": "Shipment or parcel serial number"
    },
    "eventType": {
      "type": "string",
      "enum": [
        "BOOKED",
        "DISPATCHED",
        "IN_TRANSIT",
        "OUT_FOR_DELIVERY",
        "DELIVERED",
        "EXCEPTION",
        "VOID"
      ],
      "description": "Harmonized event type"
    },
    "timestamp": {
      "type": "integer",
      "minimum": 0,
      "description": "Unix timestamp (seconds)"
    },
    "location": {
      "type": "string",
      "description": "Optional location/facility code"
    }
  }
}
