{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://api.dship.dev/schemas/config/service-config.json",
  "title": "Service Capabilities Config",
  "description": "Optional config for Service contract capabilities_config at deploy. For integration guidance only; contract does not validate structure. Passed as opaque ManagedBuffer at init.",
  "type": "object",
  "properties": {
    "serviceId": {
      "type": "string",
      "description": "Service ID (e.g. STANDARD, EXPRESS, RETURN). Shipment maps this to contract address."
    },
    "routes": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "originCountry": { "type": "string" },
          "destinationCountry": { "type": "string" },
          "region": { "type": "string" }
        }
      },
      "description": "Supported origin/destination routes"
    },
    "addons": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "amount": { "type": "string", "description": "Wei as string (optional)" }
        }
      },
      "description": "Available addons (e.g. insurance, signature)"
    }
  }
}
